{
  "name": "payload-plugin-algolia",
  "version": "0.1.0",
  "homepage:": "https://github.comw/wkentdag/payload-plugin-algolia",
  "repository": "git@github.com:wkentdag/payload-plugin-algolia.git",
  "description": "Algolia search plugin for PayloadCMS",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.9.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "keywords": [
    "payload",
    "cms",
    "plugin",
    "algolia"
  ],
  "scripts": {
    "build": "yarn copyfiles && yarn build:types && yarn build:swc",
    "build:swc": "swc ./src -d ./dist --config-file .swcrc --strip-leading-paths",
    "build:types": "tsc --outDir dist --rootDir ./src",
    "copyfiles": "copyfiles -u 1 \"src/**/*.{html,css,scss,ttf,woff,woff2,eot,svg,jpg,png,json}\" dist/",
    "clean": "rimraf dist",
    "dev": "cross-env PAYLOAD_CONFIG_PATH=./dev/payload.config.ts next dev dev --turbo",
    "dev:payload": "cross-env PAYLOAD_CONFIG_PATH=./dev/payload.config.ts payload",
    "generate:types": "cross-env PAYLOAD_CONFIG_PATH=./dev/payload.config.ts payload generate:types",
    "lint": "eslint src",
    "lint:fix": "eslint --fix --ext .ts,.tsx src",
    "prerelease": "yarn clean && yarn build && yarn test",
    "release": "release-it",
    "test": "cross-env NODE_ENV=test vitest run --config ./vitest.config.js"
  },
  "author": "Will Kent-Daggett",
  "license": "MIT",
  "peerDependencies": {
    "payload": "^3.0.0"
  },
  "dependencies": {
    "algoliasearch": "5.52.3"
  },
  "devDependencies": {
    "@payloadcms/db-mongodb": "3.84.1",
    "@payloadcms/next": "3.84.1",
    "@payloadcms/richtext-lexical": "3.84.1",
    "@payloadcms/ui": "3.84.1",
    "@swc/cli": "0.6.0",
    "@swc/core": "1.3.0",
    "@types/node": "22.10.0",
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "@typescript-eslint/eslint-plugin": "5.12.1",
    "@typescript-eslint/parser": "5.12.1",
    "copyfiles": "2.4.1",
    "cross-env": "7.0.3",
    "dotenv": "16.4.0",
    "eslint": "8.19.0",
    "eslint-config-airbnb-base": "14.2.1",
    "eslint-config-prettier": "8.5.0",
    "eslint-plugin-import": "2.25.4",
    "eslint-plugin-prettier": "4.0.0",
    "mongodb-memory-server": "10.1.4",
    "next": "15.2.0",
    "payload": "3.84.1",
    "prettier": "3.4.2",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "release-it": "17.2.0",
    "rimraf": "5.0.0",
    "sharp": "0.33.5",
    "typescript": "5.7.0",
    "vite-tsconfig-paths": "5.0.0",
    "vitest": "3.0.0"
  },
  "packageManager": "yarn@1.22.22+sha1.ac34549e6aa8e7ead463a7407e1c7390f61a6610"
}
